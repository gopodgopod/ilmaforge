  <!-- Live date in footer -->
  <script>
    (function () {
      const now  = new Date();
      const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      const mons = ['January','February','March','April','May','June','July','August','September','October','November','December'];

      const dayName = days[now.getDay()];
      const dateStr = mons[now.getMonth()] + ' ' + now.getDate();
      const yearStr = String(now.getFullYear());

      // Populate all four footer instances
      [1, 2, 3, 4].forEach(n => {
        const d = document.getElementById('footerDay'  + (n === 1 ? '' : n));
        const m = document.getElementById('footerDate' + (n === 1 ? '' : n));
        const y = document.getElementById('footerYear' + (n === 1 ? '' : n));
        if (d) d.textContent = dayName;
        if (m) m.textContent = dateStr;
        if (y) y.textContent = yearStr;
      });
    })();
  </script>

